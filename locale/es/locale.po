msgid "plugins.generic.sliderHome.settings.form.success"
msgstr "La configuración del slider ha sido actualizada. <a href=\"{$url}\" target=\"_blank\">Ver ahora</a>"

msgid "plugins.generic.sliderHome.settings.form.groupLabel"
msgstr "Configuración del slider"

msgid "plugins.generic.sliderHome.settings.form.groupDescription"
msgstr "Atención:<br> La altura del slider está determinada por la altura de la mayor imagen mostrada. Sólo si esta altura excede la resolución vertical de la pantalla se puede limitar la altura del slider estableciendo la altura máxima del slider como porcentaje de la resolución vertical de la pantalla. De lo contrario, este ajuste no tendrá ningún efecto; se escalarán tanto la altura como la anchura de las imágenes.<br>Para utilizar todo el ancho del slider prepare las imágenes con alturas inferiores a la resolución vertical de la pantalla."

msgid "plugins.generic.sliderHome.settings.form.fallbackLocale.description"
msgstr "Esta opción determina si se aplica o no el idioma principal para los campos localizados (Derechos de autor, Contenido HTML, Texto alternativo de imagen) si están vacíos."

msgid "plugins.generic.sliderHome.settings.form.fallbackLocale.boxLabel"
msgstr "Configuración de localización"

msgid "plugins.generic.sliderHome.settings.form.fallbackLocale.useNone"
msgstr "Actual {$label}"

