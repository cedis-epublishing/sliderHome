msgid "plugins.generic.sliderHome.settings.form.success"
msgstr "The slider settings have been updated. <a href=\"{$url}\" target=\"_blank\">View Now</a>"

msgid "plugins.generic.sliderHome.settings.form.groupLabel"
msgstr "Slider Settings"

msgid "plugins.generic.sliderHome.settings.form.groupDescription"
msgstr "Please note:<br>The slider height is determined by the height of largest image shown. Only if this height exceeds the vertical resolution of the screen the slider height can be limited by setting the maximum slider height as percentage of the screen vertical resolution. Otherwise this setting will have no effect. Both, the height and the width of the images will be scaled.<br>To use the full slider width prepare the images with heights smaller than the vertical screen  resolution."

msgid "plugins.generic.sliderHome.settings.form.fallbackLocale.description"
msgstr "This option determines whether or not to apply the primary language for localized fields (Copyright, HTML Content, Image Alt Text) if they are empty."

msgid "plugins.generic.sliderHome.settings.form.fallbackLocale.boxLabel"
msgstr "Localization settings"

msgid "plugins.generic.sliderHome.settings.form.fallbackLocale.useNone"
msgstr "Current {$label}"

