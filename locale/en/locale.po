msgstr "Maximum slider height as percentage of screen height."

msgid "plugins.generic.sliderHome.settings.form.maxHeight"
msgstr "Slider height"

msgid "plugins.generic.sliderHome.settings.form.maxHeight.error"
msgstr "Error: slider height should be in the range of 0 to 100!"

msgid "plugins.generic.sliderHome.settings.form.speed.description"
msgstr "Duration of transition between slides (in ms)."

msgid "plugins.generic.sliderHome.settings.form.speed"
msgstr "Slider speed"

msgid "plugins.generic.sliderHome.settings.form.speed.error"
msgstr "Error: slider speed should be a positive number!"

msgid "plugins.generic.sliderHome.settings.form.delay.description"
msgstr "Delay between transitions (in ms)."

msgid "plugins.generic.sliderHome.settings.form.delay"
msgstr "Slider delay"

